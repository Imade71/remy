generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String       @id @default(cuid())
  name                   String?
  email                  String       @unique
  emailVerified          DateTime?
  image                  String?
  passwordHash           String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  stripeCurrentPeriodEnd DateTime?
  subscriptionStatus     String?
  accounts               Account[]
  sessions               Session[]
  intakeData             IntakeData?
  messages               UserMessage[]
  dailyUsages            DailyUsage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model IntakeData {
  id          String   @id @default(cuid())
  userId      String   @unique
  program     String
  goal        String
  familiarity String
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CachedAnswer {
  id        String    @id @default(cuid())
  program   String
  question  String
  answer    String
  embedding String
  hitCount  Int       @default(0)
  lastHitAt DateTime?
  createdAt DateTime  @default(now())

  @@index([program])
}

model UserMessage {
  id             String   @id @default(cuid())
  userId         String
  role           String
  content        String
  imageData      String?
  imageMediaType String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model DailyUsage {
  id              String   @id @default(cuid())
  userId          String
  date            String
  messageCount    Int      @default(0)
  screenshotCount Int      @default(0)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
